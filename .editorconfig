root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{yaml,yml}]
indent_size = 2

[*.{json,json5}]
indent_size = 2

[*.sh]
indent_size = 2
shell_variant = posix

[Dockerfile*]
indent_size = 2

[*.tf]
indent_size = 2

[*.{hs,swift}]
indent_size = 2
