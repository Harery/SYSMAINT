# OS/editor junk
.DS_Store
.idea/
.vscode/
*~
*.swp
*.swo

# Logs and temps
*.log
*.tmp

# Python caches
__pycache__/
.pytest_cache/
*.pyc

# Go build artifacts
bin/
dist/
build/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage/
coverage.out
coverage.html

# Go module cache
go.sum

# IDE
.fleet/
*.iml

# Runtime artifacts
scanner_artifacts/

# Local config (don't commit secrets)
.env
.env.local
*.pem
*.key

# Test artifacts
tests/*.log
tests/__pycache__/
tests/results/*.json
!tests/results/test_result_schema.json

# Performance baselines
tests/performance_baselines/*.txt
tests/performance_baselines/*.md

# Debian build
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/*.substvars
debian/*.debhelper
debian/sysmaint/
*.deb
*.build
*.changes
*.buildinfo
*.tar.gz

# PULSE runtime
.pulse/cache/
.pulse/tmp/

# Database files (keep schema)
*.db
!migrations/*.sql
