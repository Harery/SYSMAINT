#!/usr/bin/env bash
cmd_name="$1"
shift || true
printf '[realmodesandbox] %s %s\n' "$cmd_name" "$*" >&2
# Optional failure simulation: REALMODE_FAIL_LIST="cmd1,cmd2" or REALMODE_FAIL_ON_ARG="pattern"
should_fail=false
if [[ -n "${REALMODE_FAIL_LIST:-}" ]]; then
  IFS=',' read -r -a _fail_list <<<"$REALMODE_FAIL_LIST"
  for f in "${_fail_list[@]}"; do [[ "$f" == "$cmd_name" ]] && should_fail=true; done
fi
if [[ -n "${REALMODE_FAIL_ON_ARG:-}" ]]; then
  for arg in "$@"; do [[ "$arg" == *"$REALMODE_FAIL_ON_ARG"* ]] && should_fail=true; done
fi
# Simulate light work for commands that expect stdout noise
case "$cmd_name" in
  apt|apt-get|apt-cache|dpkg|dpkg-query)
    echo "Reading package lists..."
    echo "Building dependency tree..."
    ;;
  snap)
    echo "All snaps up to date"
    ;;
  flatpak)
    echo "Looking for updates..."
    ;;
  systemctl)
    # Keep stdout empty so callers that parse output behave normally
    :
    ;;
  ping)
    echo "PING placeholder"
    ;;
  *)
    :
    ;;
 esac
if $should_fail; then
  printf '[realmodesandbox] simulated failure for %s\n' "$cmd_name" >&2
  exit 42
fi
exit 0
