# Helper to record a phase skipped due to missing capability (deduplicated)
_skip_cap() {
  local phase="$1" cap="$2" entry
  entry="${phase}:${cap}"
  local e
  for e in "${SKIPPED_CAPABILITIES[@]}"; do
    [[ "$e" == "$entry" ]] && return 0
  done
  SKIPPED_CAPABILITIES+=("$entry")
}

