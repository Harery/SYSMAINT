repos:
  - repo: https://github.com/Harery/OCTALUM-PULSE
    branches: [main]

labels:
  - dependencies
  - go

schedule:
  interval: daily
  time: "06:00"
  timezone: UTC

commitMessage:
  prefix: "deps"
  includeScope: true

prConcurrentLimit: 3

prHourlyLimit: 2

postUpgradeTasks:
  commands:
    - "go mod tidy"
  fileFilters:
    - "go.mod"
    - "go.sum"
